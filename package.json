{
  "name": "otter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "vite build && tsc -p tsconfig.server.json && tsc -p tsconfig.scripts.json",
    "start": "node dist/scripts/migrate.js && node dist/server/server.js",
    "migrate": "tsx scripts/migrate.ts",
    "db:reset:dev": "docker compose -f compose.dev.yml down -v",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.scripts.json",
    "test": "node --import tsx --test src/*.test.ts src/**/*.test.ts src/**/*.test.tsx",
    "biome:ci": "biome ci .",
    "check": "npm run biome:ci && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.3.0",
    "@tanstack/react-query": "^5.101.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "lucide-react": "^1.26.0",
    "pg": "^8.22.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/express": "^4.17.25",
    "@types/node": "^25.0.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "shadcn": "^4.14.1",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
